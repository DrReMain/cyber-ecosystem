{
  "$schema": "../.nx/installation/node_modules/nx/schemas/project-schema.json",
  "name": "tools",
  "root": "tools",
  "targets": {
    "go:init": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "commands": [
          "go install github.com/bufbuild/buf/cmd/buf@latest",
          "go install github.com/go-kratos/kratos/cmd/kratos/v2@latest",
          "go install google.golang.org/protobuf/cmd/protoc-gen-go@latest",
          "go install google.golang.org/grpc/cmd/protoc-gen-go-grpc@latest",
          "go install github.com/go-kratos/kratos/cmd/protoc-gen-go-http/v2@latest",
          "go install github.com/go-kratos/kratos/cmd/protoc-gen-go-errors/v2@latest",
          "go install github.com/google/gnostic/cmd/protoc-gen-openapi@latest"
        ],
        "parallel": false
      }
    },
    "go:tidy": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "go mod tidy"
      }
    },
    "buf:dep": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "buf dep update"
      }
    },
    "buf:format": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "buf format -w"
      }
    },
    "buf:lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "buf lint"
      }
    },
    "docker:up": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}/tools/docker",
        "command": "docker compose up -d"
      }
    },
    "docker:down": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}/tools/docker",
        "command": "docker compose down"
      }
    },
    "docker:logs": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}/tools/docker",
        "command": "docker compose logs -f"
      }
    },
    "docker:ps": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}/tools/docker",
        "command": "docker compose ps"
      }
    },
    "docker:restart": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}/tools/docker",
        "command": "docker compose restart"
      }
    },
    "docker:clean": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}/tools/docker",
        "command": "docker compose down -v --remove-orphans"
      }
    },
    "docker:postgres": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}/tools/docker",
        "command": "docker compose up -d postgres"
      }
    },
    "docker:redis": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}/tools/docker",
        "command": "docker compose up -d redis"
      }
    },
    "docker:jaeger": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}/tools/docker",
        "command": "docker compose up -d jaeger"
      }
    },
    "docker:prometheus": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}/tools/docker",
        "command": "docker compose up -d prometheus"
      }
    },
    "docker:grafana": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}/tools/docker",
        "command": "docker compose up -d grafana"
      }
    },
    "docker:monitoring": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}/tools/docker",
        "command": "docker compose up -d prometheus grafana"
      }
    }
  }
}
