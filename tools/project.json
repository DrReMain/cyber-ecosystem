{
  "$schema": "../.nx/installation/node_modules/nx/schemas/project-schema.json",
  "name": "tools",
  "root": "tools",
  "targets": {
    "go:init": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "commands": [
          "go install github.com/fullstorydev/grpcurl/cmd/grpcurl@latest",
          "go install github.com/bufbuild/buf/cmd/buf@latest",
          "go install github.com/go-kratos/kratos/cmd/kratos/v2@latest",
          "go get -tool connectrpc.com/connect/cmd/protoc-gen-connect-go@latest",
          "go get -tool github.com/go-kratos/kratos/cmd/protoc-gen-go-errors/v2@latest",
          "go get -tool github.com/go-kratos/kratos/cmd/protoc-gen-go-http/v2@latest",
          "go get -tool github.com/google/gnostic/cmd/protoc-gen-openapi@latest",
          "go get -tool google.golang.org/grpc/cmd/protoc-gen-go-grpc@latest",
          "go get -tool google.golang.org/protobuf/cmd/protoc-gen-go@latest",
          "go get -tool github.com/daixiang0/gci@latest"
        ],
        "parallel": false
      }
    },
    "buf:dep": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "buf dep update"
      }
    },
    "buf:format": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "buf format -w"
      }
    },
    "debug:jwt": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go run go-jwt/main.go"
      }
    },
    "gci:check": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "go tool gci list --skip-generated --custom-order -s standard -s default -s 'Prefix(github.com/go-kratos/kratos)' -s 'Prefix(cyber-ecosystem/shared-go,cyber-ecosystem/contracts)' -s 'Prefix(cyber-ecosystem/apps)' ."
      }
    },
    "gci:format": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "go tool gci write --skip-generated --custom-order -s standard -s default -s 'Prefix(github.com/go-kratos/kratos)' -s 'Prefix(cyber-ecosystem/shared-go,cyber-ecosystem/contracts)' -s 'Prefix(cyber-ecosystem/apps)' ."
      }
    },
    "biome:check": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "biome check ."
      }
    },
    "biome:format": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "biome check . --write"
      }
    }
  }
}
