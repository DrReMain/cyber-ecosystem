{
  "$schema": "../../../../.nx/installation/node_modules/nx/schemas/project-schema.json",
  "name": "template_client_admin",
  "root": "apps/template/clients/admin",
  "projectType": "application",
  "targets": {
    "biome:check": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "pnpm run lint"
      }
    },
    "biome:format": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "pnpm run lint:fix"
      }
    },
    "messages:gen": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "pnpm run messages:gen"
      }
    },
    "messages:check": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "pnpm run messages:check"
      }
    },
    "proto:openapi": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "openapi-ts -f hey-api.config.ts"
      }
    },
    "proto:connect": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "buf generate --template apps/template/clients/admin/buf.gen.client.yaml --path apps/template/api --include-imports"
      }
    }
  }
}
