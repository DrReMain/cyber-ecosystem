# API base URLs (used by SSR to directly connect to backends)
# In development, these point to local services.
# In production, these point to the actual backend hosts.
HTTP_API_URL=http://localhost:11000
CONNECT_API_URL=http://localhost:13000

# Client-side URLs (VITE_ prefix required by Vite)
VITE_SITE_URL=https://cyber-ecosystem.com

# GlitchTip DSN — leave empty to disable error reporting
# Development:  http://<key>@localhost:8000/<project-id>
# Production:   https://<key>@glitchtip.example.com/<project-id>
VITE_GLITCHTIP_DSN=

# OpenTelemetry — OTLP HTTP exporter URL
VITE_OTEL_URL=/otel/v1/traces
