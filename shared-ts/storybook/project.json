{
  "$schema": "../../.nx/installation/node_modules/nx/schemas/project-schema.json",
  "name": "shared_storybook",
  "root": "shared-ts/storybook",
  "projectType": "library",
  "targets": {
    "biome:check": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "pnpm run lint"
      }
    },
    "biome:format": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "pnpm run lint:fix"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "pnpm run typecheck"
      }
    }
  }
}
