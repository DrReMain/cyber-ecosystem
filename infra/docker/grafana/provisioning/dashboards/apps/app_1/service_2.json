        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "expr": "sum(rate(server_requests_code_total{app=\"app_1\", service=\"service_2\"}[5m]))",
