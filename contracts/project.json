{
  "$schema": "../.nx/installation/node_modules/nx/schemas/project-schema.json",
  "name": "contracts",
  "root": "contracts",
  "targets": {
    "proto:common": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": ["buf generate --template buf.gen.yaml --path common"],
        "parallel": true
      }
    },
    "proto:auth": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": ["buf generate --template buf.gen.yaml --path auth"],
        "parallel": true
      }
    },
    "proto:desc": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": ["buf generate --template buf.gen.yaml --path desc"],
        "parallel": true
      }
    },
    "proto:errors": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": ["buf generate --template buf.gen.yaml --path errors --exclude-path errors/errors.proto"],
        "parallel": true
      }
    },
    "proto": {
      "executor": "nx:run-commands",
      "dependsOn": ["proto:common", "proto:auth", "proto:desc", "proto:errors"],
      "options": {
        "command": "echo 'proto generation completed'"
      }
    }
  }
}
