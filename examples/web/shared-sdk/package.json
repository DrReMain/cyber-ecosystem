{
  "name": "shared-sdk",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./connect-web": {
      "types": "./dist/connect-web/index.d.ts",
      "import": "./dist/connect-web/index.js"
    },
    "./ts-rest": {
      "types": "./dist/ts-rest/index.d.ts",
      "import": "./dist/ts-rest/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "connect-web": [
        "./dist/connect-web/index.d.ts"
      ],
      "ts-rest": [
        "./dist/ts-rest/index.d.ts"
      ],
      "types": [
        "./dist/types/index.d.ts"
      ],
      "errors": [
        "./dist/errors/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "generated"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ts-rest/core": "^3.52.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}